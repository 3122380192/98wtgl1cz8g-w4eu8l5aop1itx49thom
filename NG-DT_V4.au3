		$ACALL = DllCall("user32.dll", "handle", "LoadImageW", "handle", $HINSTANCE, $SIMAGETYPE, $SIMAGE, "uint", $ITYPE, "int", $IXDESIRED, "int", $IYDESIRED, "uint", $ILOAD)
		If @error Then Return SetError(@error, @extended, 0)
		Return $ACALL[0]
	EndFunc
