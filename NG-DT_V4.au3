	Func _WinAPI_GetModuleHandle($SMODULENAME)
		If $SMODULENAME = "" Then $SMODULENAME = Null
		Local $ACALL = DllCall("kernel32.dll", "handle", "GetModuleHandleW", "wstr", $SMODULENAME)
		If @error Then Return SetError(@error, @extended, 0)
		Return $ACALL[0]
