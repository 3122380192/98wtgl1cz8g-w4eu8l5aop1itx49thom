Global Const $CP_SYMBOL = 42
Global Const $CP_SHIFT_JIS = 932
Global Const $CP_UTF16 = 1200
Global Const $CP_UNICODE = $CP_UTF16
Global Const $CP_UTF7 = 65000
Global Const $CP_UTF8 = 65001
