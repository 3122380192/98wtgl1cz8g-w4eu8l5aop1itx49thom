	Func _WinAPI_InProcess($HWND, ByRef $HLASTWND)
		If $HWND = $HLASTWND Then Return True
		Local $IPID
		_WinAPI_GetWindowThreadProcessId($HWND, $IPID)
		If ($IPID = @AutoItPID) Then
			$HLASTWND = $HWND
			Return True
		EndIf
		Return False
	EndFunc
