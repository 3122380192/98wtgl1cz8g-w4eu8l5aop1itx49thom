	Func _WinAPI_SetFRBuffer($ICHARS)
		$ICHARS = Number($ICHARS)
		If $ICHARS < 80 Then
			$ICHARS = 80
		EndIf
		$__G_IFRBUFFERSIZE = $ICHARS + 1
		Return 1
	EndFunc
