	EndFunc
	Func _WinAPI_SetCompression($SFILEPATH, $ICOMPRESSION)
		Local $HFILE = _WinAPI_CreateFileEx($SFILEPATH, $OPEN_EXISTING, $GENERIC_READWRITE, $FILE_SHARE_READWRITE, $FILE_FLAG_BACKUP_SEMANTICS)
