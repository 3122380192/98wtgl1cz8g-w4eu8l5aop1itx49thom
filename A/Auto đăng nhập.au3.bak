	Func _WinAPI_CreateProcess($SAPPNAME, $SCOMMAND, $TSECURITY, $TTHREAD, $BINHERIT, $IFLAGS, $PENVIRON, $SDIR, $TSTARTUPINFO, $TPROCESS)
		Local $TCOMMAND = 0
