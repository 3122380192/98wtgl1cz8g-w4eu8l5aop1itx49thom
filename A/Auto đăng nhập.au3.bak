	Func _WinAPI_CoTaskMemRealloc($PMEMORY, $ISIZE)
		Local $ACALL = DllCall("ole32.dll", "ptr", "CoTaskMemRealloc", "ptr", $PMEMORY, "ulong_ptr", $ISIZE)
