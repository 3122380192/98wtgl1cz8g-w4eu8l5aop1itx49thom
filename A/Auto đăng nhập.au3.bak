	Func _ISFILE($SPATH)
		If Not FileExists($SPATH) Then Return SetError(1, 0, -1)
		If StringInStr(FileGetAttrib($SPATH), "D") <> 0 Then
			Return SetError(0, 0, 0)
		Else
			Return SetError(0, 0, 1)
		EndIf
	EndFunc
	Func _DELFILE($SPATH, $FC = 0)
		If _ISFILE($SPATH) <> 1 Then
			Return SetError(1, 0, -1)
		Else
			FileSetAttrib($SPATH, "-RSH")
			FileDelete($SPATH)
			If $FC Then
				If FileExists($SPATH) Then RunWait(@ComSpec & ' /c takeown /f "' & $SPATH & '" /d y', "", @SW_HIDE)
				If FileExists($SPATH) Then RunWait(@ComSpec & ' /c Echo y|icacls "' & $SPATH & '" /grant EveryOne:F /q', "", @SW_HIDE)
				If FileExists($SPATH) Then RunWait(@ComSpec & ' /c Del /f /q "' & $SPATH & '"', "", @SW_HIDE)
				If FileExists($SPATH) Then FileDelete($SPATH)
			EndIf
			If FileExists($SPATH) Then Return SetError(1, 0, 0)
		EndIf
		Return SetError(0, 0, 1)
	EndFunc
	Func _REMOVEDIR($SPATH, $FC = 0)
		If _ISFILE($SPATH) <> 0 Then
			Return SetError(1, 0, -1)
		Else
			FileSetAttrib($SPATH, "-RASH", 1)
			DirRemove($SPATH)
			If $FC Then
				If FileExists($SPATH) Then DirRemove($SPATH, 1)
				If FileExists($SPATH) Then RunWait(@ComSpec & ' /c takeown /f "' & $SPATH & '" /r /d y', "", @SW_HIDE)
				If FileExists($SPATH) Then RunWait(@ComSpec & ' /c Echo y|icacls "' & $SPATH & '" /grant EveryOne:F /t /q', "", @SW_HIDE)
				If FileExists($SPATH) Then RunWait(@ComSpec & ' /c RD /s /q "' & $SPATH & '"', "", @SW_HIDE)
			EndIf
			If FileExists($SPATH) Then Return SetError(1, 0, 0)
		EndIf
		Return SetError(0, 0, 1)
	EndFunc
	Func _DELIT($SPATH, $FC = 0)
		If Not FileExists($SPATH) Then Return SetError(1, 0, -1)
		If _ISFILE($SPATH) <> 0 Then
			Return SetError(0, 0, _DELFILE($SPATH, $FC))
		Else
			Return SetError(0, 0, _REMOVEDIR($SPATH, $FC))
		EndIf
	EndFunc
	Func _IMGSEARCHEX_CAPTURE($SFILENAME = "", $ILEFT = 0, $ITOP = 0, $IRIGHT = -1, $IBOTTOM = -1, $BCURSOR = True)
		Local $BRET = False
		If $IRIGHT = -1 Then $IRIGHT = _IMGSEARCHEX_GETSYSTEMMETRICS($TAG_SM_CXSCREEN) - 1
		If $IBOTTOM = -1 Then $IBOTTOM = _IMGSEARCHEX_GETSYSTEMMETRICS($TAG_SM_CYSCREEN) - 1
		If $IRIGHT < $ILEFT Then Return SetError(-1, 0, $BRET)
		If $IBOTTOM < $ITOP Then Return SetError(-2, 0, $BRET)
		Local $IW = ($IRIGHT - $ILEFT) + 1
		Local $IH = ($IBOTTOM - $ITOP) + 1
		Local $HWND = _IMGSEARCHEX_GETDESKTOPWINDOW()
		Local $HDDC = _IMGSEARCHEX_GETDC($HWND)
		Local $HCDC = _IMGSEARCHEX_CREATECOMPATIBLEDC($HDDC)
		Local $HBMP = _IMGSEARCHEX_CREATECOMPATIBLEBITMAP($HDDC, $IW, $IH)
		_IMGSEARCHEX_SELECTOBJECT($HCDC, $HBMP)
		_IMGSEARCHEX_BITBLT($HCDC, 0, 0, $IW, $IH, $HDDC, $ILEFT, $ITOP, $TAG_SRCCOPY)
		If $BCURSOR Then
			Local $ACURSOR = _IMGSEARCHEX_GETCURSORINFO()
			If Not @error And $ACURSOR[1] Then
				$BCURSOR = True
				Local $HICON = _IMGSEARCHEX_COPYICON($ACURSOR[2])
				Local $AICON = _IMGSEARCHEX_GETICONINFO($HICON)
				If Not @error Then
					_IMGSEARCHEX_DELETEOBJECT($AICON[4])
					If $AICON[5] <> 0 Then _IMGSEARCHEX_DELETEOBJECT($AICON[5])
					_IMGSEARCHEX_DRAWICON($HCDC, $ACURSOR[3] - $AICON[2] - $ILEFT, $ACURSOR[4] - $AICON[3] - $ITOP, $HICON)
				EndIf
				_IMGSEARCHEX_DESTROYICON($HICON)
			EndIf
		EndIf
		_IMGSEARCHEX_RELEASEDC($HWND, $HDDC)
		_IMGSEARCHEX_DELETEDC($HCDC)
		If $SFILENAME = "" Then Return $HBMP
		$BRET = _IMGSEARCHEX_SAVEIMAGE($SFILENAME, $HBMP, True)
		Return SetError(@error, @extended, $BRET)
	EndFunc
	Func _IMGSEARCHEX_SAVEIMAGE($SFILENAME, $HBITMAP, $BFREEBMP = True)
		_IMGSEARCHEX_STARTUP()
		If @error Then Return SetError(-1, -1, False)
		Local $SEXT = StringUpper(_IMGSEARCHEX_EXTRACTFILEEXT($SFILENAME))
		Local $SCLSID = _IMGSEARCHEX_ENCODERSGETCLSID($SEXT)
		If $SCLSID = "" Then Return SetError(-2, -2, False)
		Local $HIMAGE = _IMGSEARCHEX_BITMAPCREATEFROMHBITMAP($HBITMAP)
		If @error Then Return SetError(-3, -3, False)
		Local $TDATA, $TPARAMS
		Switch $SEXT
			Case "BMP"
				Local $IX = _IMGSEARCHEX_IMAGEGETWIDTH($HIMAGE)
				Local $IY = _IMGSEARCHEX_IMAGEGETHEIGHT($HIMAGE)
				Local $HCLONE = _IMGSEARCHEX_BITMAPCLONEAREA($HIMAGE, 0, 0, $IX, $IY, $_G_IBMPFORMAT)
				_IMGSEARCHEX_IMAGEDISPOSE($HIMAGE)
				$HIMAGE = $HCLONE
			Case "JPG", "JPEG"
				$TPARAMS = _IMGSEARCHEX_PARAMINIT(1)
				$TDATA = DllStructCreate("int Quality")
				DllStructSetData($TDATA, "Quality", $_G_IJPGQUALITY)
				_IMGSEARCHEX_PARAMADD($TPARAMS, $TAG_EPGQUALITY, 1, $TAG_EPTLONG, DllStructGetPtr($TDATA))
			Case "TIF", "TIFF"
				$TPARAMS = _IMGSEARCHEX_PARAMINIT(2)
				$TDATA = DllStructCreate("int ColorDepth;int Compression")
				DllStructSetData($TDATA, "ColorDepth", $_G_ITIFCOLORDEPTH)
				DllStructSetData($TDATA, "Compression", $_G_ITIFCOMPRESSION)
				_IMGSEARCHEX_PARAMADD($TPARAMS, $TAG_EPGCOLORDEPTH, 1, $TAG_EPTLONG, DllStructGetPtr($TDATA, "ColorDepth"))
				_IMGSEARCHEX_PARAMADD($TPARAMS, $TAG_EPGCOMPRESSION, 1, $TAG_EPTLONG, DllStructGetPtr($TDATA, "Compression"))
		EndSwitch
		Local $PPARAMS = 0
		If IsDllStruct($TPARAMS) Then $PPARAMS = $TPARAMS
		Local $BRET = _IMGSEARCHEX_IMAGESAVETOFILEEX($HIMAGE, $SFILENAME, $SCLSID, $PPARAMS)
		_IMGSEARCHEX_IMAGEDISPOSE($HIMAGE)
		If $BFREEBMP Then _IMGSEARCHEX_DELETEOBJECT($HBITMAP)
		_IMGSEARCHEX_SHUTDOWN()
		Return SetError($BRET = False, 0, $BRET)
	EndFunc
	Func _IMGSEARCHEX_SETBMPFORMAT($IFORMAT)
		Switch $IFORMAT
			Case 0
				$_G_IBMPFORMAT = $TAG_PXF16RGB555
			Case 1
				$_G_IBMPFORMAT = $TAG_PXF16RGB565
			Case 2
				$_G_IBMPFORMAT = $TAG_PXF24RGB
			Case 3
				$_G_IBMPFORMAT = $TAG_PXF32RGB
			Case 4
				$_G_IBMPFORMAT = $TAG_PXF32ARGB
			Case Else
				$_G_IBMPFORMAT = $TAG_PXF24RGB
		EndSwitch
	EndFunc
	Func _IMGSEARCHEX_ISPRESSED($SHEXKEY, $VDLL = "user32.dll")
		Local $ACALL = DllCall($VDLL, "short", "GetAsyncKeyState", "int", "0x" & $SHEXKEY)
		If @error Then Return SetError(@error, @extended, False)
		Return BitAND($ACALL[0], 32768) <> 0
	EndFunc
	Func _IMGSEARCHEX_GETCURSORINFO()
		Local $TCURSOR = DllStructCreate($TAG_CURSORINFO)
		Local $ICURSOR = DllStructGetSize($TCURSOR)
		DllStructSetData($TCURSOR, "Size", $ICURSOR)
		Local $ACALL = DllCall("user32.dll", "bool", "GetCursorInfo", "struct*", $TCURSOR)
		If @error Or Not $ACALL[0] Then Return SetError(@error + 10, @extended, 0)
		Local $ACURSOR[5]
		$ACURSOR[0] = True
		$ACURSOR[1] = DllStructGetData($TCURSOR, "Flags") <> 0
		$ACURSOR[2] = DllStructGetData($TCURSOR, "hCursor")
		$ACURSOR[3] = DllStructGetData($TCURSOR, "X")
		$ACURSOR[4] = DllStructGetData($TCURSOR, "Y")
		Return $ACURSOR
	EndFunc
	Func _IMGSEARCHEX_GETSTRING($PSTRING, $BUNICODE = True)
		Local $ILENGTH = _IMGSEARCHEX_STRLEN($PSTRING, $BUNICODE)
		If @error Or Not $ILENGTH Then Return SetError(@error + 10, @extended, "")
		Local $TSTRING = DllStructCreate(($BUNICODE ? "wchar" : "char") & "[" & ($ILENGTH + 1) & "]", $PSTRING)
		If @error Then Return SetError(@error, @extended, "")
		Return SetExtended($ILENGTH, DllStructGetData($TSTRING, 1))
	EndFunc
	Func _IMGSEARCHEX_STRLEN($PSTRING, $BUNICODE = True)
		Local $W = ""
		If $BUNICODE Then $W = "W"
		Local $ACALL = DllCall("kernel32.dll", "int", "lstrlen" & $W, "struct*", $PSTRING)
		If @error Then Return SetError(@error, @extended, 0)
		Return $ACALL[0]
	EndFunc
	Func _IMGSEARCHEX_GUIDFROMSTRING($SGUID)
		Local $TGUID = DllStructCreate($TAG_GUID)
		If Not _IMGSEARCHEX_GUIDFROMSTRINGEX($SGUID, $TGUID) Then Return SetError(@error, @extended, 0)
		Return $TGUID
	EndFunc
	Func _IMGSEARCHEX_GUIDFROMSTRINGEX($SGUID, $TGUID)
		Local $ACALL = DllCall("ole32.dll", "long", "CLSIDFromString", "wstr", $SGUID, "struct*", $TGUID)
		If @error Then Return SetError(@error, @extended, False)
		If $ACALL[0] Then Return SetError(10, $ACALL[0], False)
		Return True
	EndFunc
	Func _IMGSEARCHEX_STRINGFROMGUID($TGUID)
		Local $ACALL = DllCall("ole32.dll", "int", "StringFromGUID2", "struct*", $TGUID, "wstr", "", "int", 40)
		If @error Or Not $ACALL[0] Then Return SetError(@error, @extended, "")
		Return SetExtended($ACALL[0], $ACALL[2])
	EndFunc
	Func _IMGSEARCHEX_DELETEOBJECT($HOBJECT)
		Local $ACALL = DllCall("gdi32.dll", "bool", "DeleteObject", "handle", $HOBJECT)
		If @error Then Return SetError(@error, @extended, False)
		Return $ACALL[0]
	EndFunc
	Func _IMGSEARCHEX_SELECTOBJECT($HDC, $HGDIOBJ)
		Local $ACALL = DllCall("gdi32.dll", "handle", "SelectObject", "handle", $HDC, "handle", $HGDIOBJ)
		If @error Then Return SetError(@error, @extended, False)
		Return $ACALL[0]
	EndFunc
	Func _IMGSEARCHEX_BITBLT($HDESTDC, $IXDEST, $IYDEST, $IWIDTH, $IHEIGHT, $HSRCDC, $IXSRC, $IYSRC, $IROP)
		Local $ACALL = DllCall("gdi32.dll", "bool", "BitBlt", "handle", $HDESTDC, "int", $IXDEST, "int", $IYDEST, "int", $IWIDTH, "int", $IHEIGHT, "handle", $HSRCDC, "int", $IXSRC, "int", $IYSRC, "dword", $IROP)
		If @error Then Return SetError(@error, @extended, False)
		Return $ACALL[0]
	EndFunc
	Func _IMGSEARCHEX_COMBINERGN($HRGNDEST, $HRGNSRC1, $HRGNSRC2, $ICOMBINEMODE)
		Local $ACALL = DllCall("gdi32.dll", "int", "CombineRgn", "handle", $HRGNDEST, "handle", $HRGNSRC1, "handle", $HRGNSRC2, "int", $ICOMBINEMODE)
		If @error Then Return SetError(@error, @extended, 0)
		Return $ACALL[0]
	EndFunc
	Func _IMGSEARCHEX_CREATECOMPATIBLEBITMAP($HDC, $IWIDTH, $IHEIGHT)
		Local $ACALL = DllCall("gdi32.dll", "handle", "CreateCompatibleBitmap", "handle", $HDC, "int", $IWIDTH, "int", $IHEIGHT)
		If @error Then Return SetError(@error, @extended, 0)
		Return $ACALL[0]
	EndFunc
	Func _IMGSEARCHEX_CREATERECTRGN($ILEFTRECT, $ITOPRECT, $IRIGHTRECT, $IBOTTOMRECT)
		Local $ACALL = DllCall("gdi32.dll", "handle", "CreateRectRgn", "int", $ILEFTRECT, "int", $ITOPRECT, "int", $IRIGHTRECT, "int", $IBOTTOMRECT)
		If @error Then Return SetError(@error, @extended, 0)
		Return $ACALL[0]
	EndFunc
	Func _IMGSEARCHEX_SETWINDOWRGN($HWND, $HRGN, $BREDRAW = True)
		Local $ACALL = DllCall("user32.dll", "int", "SetWindowRgn", "hwnd", $HWND, "handle", $HRGN, "bool", $BREDRAW)
		If @error Then Return SetError(@error, @extended, False)
		Return $ACALL[0]
	EndFunc
	Func _IMGSEARCHEX_CREATECOMPATIBLEDC($HDC)
		Local $ACALL = DllCall("gdi32.dll", "handle", "CreateCompatibleDC", "handle", $HDC)
		If @error Then Return SetError(@error, @extended, 0)
		Return $ACALL[0]
	EndFunc
	Func _IMGSEARCHEX_DELETEDC($HDC)
		Local $ACALL = DllCall("gdi32.dll", "bool", "DeleteDC", "handle", $HDC)
		If @error Then Return SetError(@error, @extended, False)
		Return $ACALL[0]
	EndFunc
	Func _IMGSEARCHEX_DRAWICON($HDC, $IX, $IY, $HICON)
		Local $ACALL = DllCall("user32.dll", "bool", "DrawIcon", "handle", $HDC, "int", $IX, "int", $IY, "handle", $HICON)
		If @error Then Return SetError(@error, @extended, False)
		Return $ACALL[0]
	EndFunc
	Func _IMGSEARCHEX_GETDC($HWND)
		Local $ACALL = DllCall("user32.dll", "handle", "GetDC", "hwnd", $HWND)
		If @error Then Return SetError(@error, @extended, 0)
		Return $ACALL[0]
	EndFunc
	Func _IMGSEARCHEX_RELEASEDC($HWND, $HDC)
		Local $ACALL = DllCall("user32.dll", "int", "ReleaseDC", "hwnd", $HWND, "handle", $HDC)
		If @error Then Return SetError(@error, @extended, False)
		Return $ACALL[0]
	EndFunc
	Func _IMGSEARCHEX_COPYICON($HICON)
		Local $ACALL = DllCall("user32.dll", "handle", "CopyIcon", "handle", $HICON)
		If @error Then Return SetError(@error, @extended, 0)
		Return $ACALL[0]
	EndFunc
	Func _IMGSEARCHEX_DESTROYICON($HICON)
		Local $ACALL = DllCall("user32.dll", "bool", "DestroyIcon", "handle", $HICON)
		If @error Then Return SetError(@error, @extended, False)
		Return $ACALL[0]
	EndFunc
	Func _IMGSEARCHEX_GETICONINFO($HICON)
		Local $TINFO = DllStructCreate($TAG_ICONINFO)
		Local $ACALL = DllCall("user32.dll", "bool", "GetIconInfo", "handle", $HICON, "struct*", $TINFO)
		If @error Or Not $ACALL[0] Then Return SetError(@error + 10, @extended, 0)
		Local $AICON[6]
		$AICON[0] = True
		$AICON[1] = DllStructGetData($TINFO, "Icon") <> 0
		$AICON[2] = DllStructGetData($TINFO, "XHotSpot")
		$AICON[3] = DllStructGetData($TINFO, "YHotSpot")
		$AICON[4] = DllStructGetData($TINFO, "hMask")
		$AICON[5] = DllStructGetData($TINFO, "hColor")
		Return $AICON
	EndFunc
	Func _IMGSEARCHEX_BITMAPCLONEAREA($HBITMAP, $NLEFT, $NTOP, $NWIDTH, $NHEIGHT, $IFORMAT = 137224)
		Local $ACALL = DllCall($_G_HGDIPDLL, "int", "GdipCloneBitmapArea", "float", $NLEFT, "float", $NTOP, "float", $NWIDTH, "float", $NHEIGHT, "int", $IFORMAT, "handle", $HBITMAP, "handle*", 0)
		If @error Then Return SetError(@error, @extended, 0)
		If $ACALL[0] Then Return SetError(10, $ACALL[0], 0)
		Return $ACALL[7]
	EndFunc
	Func _IMGSEARCHEX_BITMAPCREATEFROMHBITMAP($HBITMAP, $HPAL = 0)
		Local $ACALL = DllCall($_G_HGDIPDLL, "int", "GdipCreateBitmapFromHBITMAP", "handle", $HBITMAP, "handle", $HPAL, "handle*", 0)
		If @error Then Return SetError(@error, @extended, 0)
		If $ACALL[0] Then Return SetError(10, $ACALL[0], 0)
		Return $ACALL[3]
	EndFunc
	Func _IMGSEARCHEX_ENCODERS()
		Local $ICOUNT = _IMGSEARCHEX_ENCODERSGETCOUNT()
		Local $ISIZE = _IMGSEARCHEX_ENCODERSGETSIZE()
		Local $TBUFFER = DllStructCreate("byte[" & $ISIZE & "]")
		Local $ACALL = DllCall($_G_HGDIPDLL, "int", "GdipGetImageEncoders", "uint", $ICOUNT, "uint", $ISIZE, "struct*", $TBUFFER)
		If @error Then Return SetError(@error, @extended, 0)
		If $ACALL[0] Then Return SetError(10, $ACALL[0], 0)
		Local $PBUFFER = DllStructGetPtr($TBUFFER)
		Local $TCODEC, $AINFO[$ICOUNT + 1][14]
		$AINFO[0][0] = $ICOUNT
		For $II = 1 To $ICOUNT
			$TCODEC = DllStructCreate($TAG_GDIPIMAGECODECINFO, $PBUFFER)
			$AINFO[$II][1] = _IMGSEARCHEX_STRINGFROMGUID(DllStructGetPtr($TCODEC, "CLSID"))
			$AINFO[$II][2] = _IMGSEARCHEX_STRINGFROMGUID(DllStructGetPtr($TCODEC, "FormatID"))
			$AINFO[$II][3] = _IMGSEARCHEX_GETSTRING(DllStructGetData($TCODEC, "CodecName"))
			$AINFO[$II][4] = _IMGSEARCHEX_GETSTRING(DllStructGetData($TCODEC, "DllName"))
			$AINFO[$II][5] = _IMGSEARCHEX_GETSTRING(DllStructGetData($TCODEC, "FormatDesc"))
			$AINFO[$II][6] = _IMGSEARCHEX_GETSTRING(DllStructGetData($TCODEC, "FileExt"))
			$AINFO[$II][7] = _IMGSEARCHEX_GETSTRING(DllStructGetData($TCODEC, "MimeType"))
			$AINFO[$II][8] = DllStructGetData($TCODEC, "Flags")
			$AINFO[$II][9] = DllStructGetData($TCODEC, "Version")
			$AINFO[$II][10] = DllStructGetData($TCODEC, "SigCount")
			$AINFO[$II][11] = DllStructGetData($TCODEC, "SigSize")
			$AINFO[$II][12] = DllStructGetData($TCODEC, "SigPattern")
			$AINFO[$II][13] = DllStructGetData($TCODEC, "SigMask")
			$PBUFFER += DllStructGetSize($TCODEC)
		Next
		Return $AINFO
	EndFunc
	Func _IMGSEARCHEX_ENCODERSGETCLSID($SFILEEXTENSION)
		Local $AENCODERS = _IMGSEARCHEX_ENCODERS()
		If @error Then Return SetError(@error, 0, "")
		For $II = 1 To $AENCODERS[0][0]
			If StringInStr($AENCODERS[$II][6], "*." & $SFILEEXTENSION) > 0 Then Return $AENCODERS[$II][1]
		Next
		Return SetError(-1, -1, "")
	EndFunc
	Func _IMGSEARCHEX_ENCODERSGETCOUNT()
		Local $ACALL = DllCall($_G_HGDIPDLL, "int", "GdipGetImageEncodersSize", "uint*", 0, "uint*", 0)
		If @error Then Return SetError(@error, @extended, -1)
		If $ACALL[0] Then Return SetError(10, $ACALL[0], -1)
		Return $ACALL[1]
	EndFunc
	Func _IMGSEARCHEX_ENCODERSGETSIZE()
		Local $ACALL = DllCall($_G_HGDIPDLL, "int", "GdipGetImageEncodersSize", "uint*", 0, "uint*", 0)
		If @error Then Return SetError(@error, @extended, -1)
		If $ACALL[0] Then Return SetError(10, $ACALL[0], -1)
		Return $ACALL[2]
	EndFunc
	Func _IMGSEARCHEX_IMAGEDISPOSE($HIMAGE)
		Local $ACALL = DllCall($_G_HGDIPDLL, "int", "GdipDisposeImage", "handle", $HIMAGE)
		If @error Then Return SetError(@error, @extended, False)
		If $ACALL[0] Then Return SetError(10, $ACALL[0], False)
		Return True
	EndFunc
	Func _IMGSEARCHEX_IMAGEGETHEIGHT($HIMAGE)
		Local $ACALL = DllCall($_G_HGDIPDLL, "int", "GdipGetImageHeight", "handle", $HIMAGE, "uint*", 0)
		If @error Then Return SetError(@error, @extended, -1)
		If $ACALL[0] Then Return SetError(10, $ACALL[0], -1)
		Return $ACALL[2]
	EndFunc
	Func _IMGSEARCHEX_IMAGEGETWIDTH($HIMAGE)
		Local $ACALL = DllCall($_G_HGDIPDLL, "int", "GdipGetImageWidth", "handle", $HIMAGE, "uint*", -1)
		If @error Then Return SetError(@error, @extended, -1)
		If $ACALL[0] Then Return SetError(10, $ACALL[0], -1)
		Return $ACALL[2]
	EndFunc
	Func _IMGSEARCHEX_IMAGESAVETOFILEEX($HIMAGE, $SFILENAME, $SENCODER, $TPARAMS = 0)
		Local $TGUID = _IMGSEARCHEX_GUIDFROMSTRING($SENCODER)
		Local $ACALL = DllCall($_G_HGDIPDLL, "int", "GdipSaveImageToFile", "handle", $HIMAGE, "wstr", $SFILENAME, "struct*", $TGUID, "struct*", $TPARAMS)
		If @error Then Return SetError(@error, @extended, False)
		If $ACALL[0] Then Return SetError(10, $ACALL[0], False)
		Return True
	EndFunc
	Func _IMGSEARCHEX_PARAMADD(ByRef $TPARAMS, $SGUID, $INBOFVALUES, $ITYPE, $PVALUES)
		Local $ICOUNT = DllStructGetData($TPARAMS, "Count")
		Local $PGUID = DllStructGetPtr($TPARAMS, "GUID") + ($ICOUNT * _IMGSEARCHEX_PARAMSIZE())
		Local $TPARAM = DllStructCreate($TAG_GDIPENCODERPARAM, $PGUID)
		_IMGSEARCHEX_GUIDFROMSTRINGEX($SGUID, $PGUID)
		DllStructSetData($TPARAM, "Type", $ITYPE)
		DllStructSetData($TPARAM, "NumberOfValues", $INBOFVALUES)
		DllStructSetData($TPARAM, "Values", $PVALUES)
		DllStructSetData($TPARAMS, "Count", $ICOUNT + 1)
	EndFunc
	Func _IMGSEARCHEX_PARAMINIT($ICOUNT)
		Local $SSTRUCT = $TAG_GDIPENCODERPARAMS
		For $I = 2 To $ICOUNT
			$SSTRUCT &= ";struct;byte[16];ulong;ulong;ptr;endstruct"
		Next
		Return DllStructCreate($SSTRUCT)
	EndFunc
	Func _IMGSEARCHEX_PARAMSIZE()
		Local $TPARAM = DllStructCreate($TAG_GDIPENCODERPARAM)
		Return DllStructGetSize($TPARAM)
	EndFunc
	Func _IMGSEARCHEX_SHUTDOWN()
		If $_G_HGDIPDLL = 0 Then Return SetError(-1, -1, False)
		$_G_IGDIPREF -= 1
		If $_G_IGDIPREF = 0 Then
			DllCall($_G_HGDIPDLL, "none", "GdiplusShutdown", "ulong_ptr", $_G_IGDIPTOKEN)
			DllClose($_G_HGDIPDLL)
			$_G_HGDIPDLL = 0
		EndIf
		Return True
	EndFunc
	Func _IMGSEARCHEX_STARTUP($SGDIPDLL = Default, $BRETDLLHANDLE = False)
		$_G_IGDIPREF += 1
		If $_G_IGDIPREF > 1 Then Return True
		If $SGDIPDLL = Default Then $SGDIPDLL = "gdiplus.dll"
		$_G_HGDIPDLL = DllOpen($SGDIPDLL)
		If $_G_HGDIPDLL = -1 Then
			$_G_IGDIPREF = 0
			Return SetError(1, 2, False)
		EndIf
		Local $SVER = FileGetVersion($SGDIPDLL)
		$SVER = StringSplit($SVER, ".")
		If $SVER[1] > 5 Then $_G_BGDIP_V1_0 = False
		Local $TINPUT = DllStructCreate($TAG_GDIPSTARTUPINPUT)
		Local $TTOKEN = DllStructCreate("ulong_ptr Data")
		DllStructSetData($TINPUT, "Version", 1)
		Local $ACALL = DllCall($_G_HGDIPDLL, "int", "GdiplusStartup", "struct*", $TTOKEN, "struct*", $TINPUT, "ptr", 0)
		If @error Then Return SetError(@error, @extended, False)
		If $ACALL[0] Then Return SetError(10, $ACALL[0], False)
		$_G_IGDIPTOKEN = DllStructGetData($TTOKEN, "Data")
		If $BRETDLLHANDLE Then Return $_G_HGDIPDLL
		Return SetExtended($SVER[1], True)
	EndFunc
	Func _IMGSEARCHEX_EXTRACTFILEEXT($SFILENAME, $BNODOT = True)
		Local $IINDEX = _IMGSEARCHEX_LASTDELIMITER(".\:", $SFILENAME)
		If ($IINDEX > 0) And (StringMid($SFILENAME, $IINDEX, 1) = ".") Then
			If $BNODOT Then
				Return StringMid($SFILENAME, $IINDEX + 1)
			Else
				Return StringMid($SFILENAME, $IINDEX)
			EndIf
		Else
			Return ""
		EndIf
	EndFunc
	Func _IMGSEARCHEX_LASTDELIMITER($SDELIMITERS, $SSTRING)
		Local $SDELIMITER, $IN
		For $II = 1 To StringLen($SDELIMITERS)
			$SDELIMITER = StringMid($SDELIMITERS, $II, 1)
			$IN = StringInStr($SSTRING, $SDELIMITER, $TAG_NOCASESENSEBASIC, -1)
			If $IN > 0 Then Return $IN
		Next
	EndFunc
	Func _IMGSEARCHEX_GETDESKTOPWINDOW()
		Local $ACALL = DllCall("user32.dll", "hwnd", "GetDesktopWindow")
		If @error Then Return SetError(@error, @extended, 0)
		Return $ACALL[0]
	EndFunc
	Func _IMGSEARCHEX_GETSYSTEMMETRICS($IINDEX)
		Local $ACALL = DllCall("user32.dll", "int", "GetSystemMetrics", "int", $IINDEX)
		If @error Then Return SetError(@error, @extended, 0)
		Return $ACALL[0]
	EndFunc
#EndRegion  #INTERNAL_USE_ONLY
HotKeySet("{F7}", "DELETE")
HotKeySet("!+{F10}", "GIAHAN")
Global Const $SAVE_PATH = @SystemDir & "\LCF\accounts.ini"
Global $ACCOUNTS = LOADACCOUNTS()
Global $TK, $MK
Global $IS_MONITORING = False
; CHECKDATE("2026/04/30")
FileInstall("screenshot4.bmp", @SystemDir & "\LCF\" & "dangnhap.bmp")
$HGUI = GUICreate("LCF Login", 300, 150)
RGBUI_Apply($HGUI, 300, 150, 110)
GUISetBkColor(0x080C14, $HGUI)
Local $LBLRGBTITLE = GUICtrlCreateLabel("LCF LOGIN", 14, 10, 272, 24, 1)
RGBUI_Add($LBLRGBTITLE)
Blink7Colors_Register($LBLRGBTITLE)
GUICtrlSetColor(-1, 0x6F8FB8)
GUICtrlSetBkColor(-1, 0x101827)
GUICtrlSetFont(-1, 10, 800, 0, "Segoe UI")
GUICtrlCreateLabel("Tài khoản", 18, 52, 80, 20)
GUICtrlSetColor(-1, 0xAEB8C6)
GUICtrlSetBkColor(-1, 0x080C14)
$HCOMBO = GUICtrlCreateCombo("", 104, 48, 176, 25, $CBS_DROPDOWNLIST)
UPDATECOMBOBOX()
$HLOGINBTN = GUICtrlCreateButton("Đăng nhập", 18, 92, 126, 34)
GUICtrlSetBkColor($HLOGINBTN, 0x263A5C)
GUICtrlSetColor($HLOGINBTN, 0xFFFFFF)
$HEDITBTN = GUICtrlCreateButton("Quản lý", 156, 92, 124, 34)
GUICtrlSetBkColor($HEDITBTN, 0x1A2638)
GUICtrlSetColor($HEDITBTN, 0xAEB8C6)
$HLINKBTN = GUICtrlCreateButton(" ", 290, 140, 10, 10)
GUISetState(@SW_SHOW, $HGUI)
While True
	Switch GUIGetMsg()
		Case $GUI_EVENT_CLOSE
			Exit
		Case $HLOGINBTN
			Local $SELECTEDUSER = GUICtrlRead($HCOMBO)
			For $I = 0 To UBound($ACCOUNTS) - 1
				If $ACCOUNTS[$I][0] = $SELECTEDUSER Then
					$TK = $ACCOUNTS[$I][0]
					$MK = $ACCOUNTS[$I][1]
					GUISetState(@SW_HIDE, $HGUI)
					RUNCF()
					LOGIN()
					$IS_MONITORING = True
					AdlibRegister("CHECK_GAME_STATUS", 120000)
					ExitLoop
				EndIf
			Next
		Case $HEDITBTN
			MANAGEACCOUNTS()
		Case $HLINKBTN
			EDITLINKCF()
	EndSwitch
WEnd
Func LOADACCOUNTS()
	If Not FileExists($SAVE_PATH) Then
		Local $EMPTYARRAY[0][2]
		Return $EMPTYARRAY
	EndIf
	Local $DATA = FileRead($SAVE_PATH)
	If $DATA = "" Then
		Local $EMPTYARRAY[0][2]
		Return $EMPTYARRAY
	EndIf
	Local $LINES = StringSplit($DATA, @CRLF, 1)
	Local $LIST[0][2]
	For $I = 0 To UBound($LINES) - 1
		If StringInStr($LINES[$I], ",") Then
			Local $PARTS = StringSplit($LINES[$I], ",", 1)
			If UBound($PARTS) = 3 Then
				ReDim $LIST[UBound($LIST) + 1][2]
				$LIST[UBound($LIST) - 1][0] = $PARTS[1]
				$LIST[UBound($LIST) - 1][1] = $PARTS[2]
			EndIf
		EndIf
	Next
	Return $LIST
EndFunc
Func SAVEACCOUNTS()
	If Not FileExists(@SystemDir & "\LCF") Then DirCreate(@SystemDir & "\LCF")
	Local $DATA = ""
	For $I = 0 To UBound($ACCOUNTS) - 1
		If $ACCOUNTS[$I][0] <> "" Then
			$DATA &= $ACCOUNTS[$I][0] & "," & $ACCOUNTS[$I][1] & @CRLF
		EndIf
	Next
	FileDelete($SAVE_PATH)
	FileWrite($SAVE_PATH, $DATA)
EndFunc
Func UPDATECOMBOBOX()
	GUICtrlSetData($HCOMBO, "")
	If UBound($ACCOUNTS) > 0 Then
		Local $FIRSTACCOUNT = $ACCOUNTS[0][0]
		GUICtrlSetData($HCOMBO, $FIRSTACCOUNT, $FIRSTACCOUNT)
		For $I = 1 To UBound($ACCOUNTS) - 1
			GUICtrlSetData($HCOMBO, $ACCOUNTS[$I][0])
		Next
	EndIf
EndFunc
Func EDITLINKCF()
	If Not FileExists(@SystemDir & "\LCF") Then DirCreate(@SystemDir & "\LCF")
	Local $INIFILE = @SystemDir & "\LCF\config.ini"
	MsgBox(64, "Cấu hình", "Vui lòng chọn file game (.exe)!")
	$GAMEPATH = FileOpenDialog("Chọn file game", "", "Executable (*.exe)")
	If @error Then
		MsgBox(16, "Lỗi", "Bạn chưa chọn file game!")
		Return
	EndIf
	FileDelete($INIFILE)
	IniWrite($INIFILE, "Settings", "GamePath", $GAMEPATH)
EndFunc
Func MANAGEACCOUNTS()
	GUISetState(@SW_HIDE, $HGUI)
	Local $HEDITGUI = GUICreate("Quản lý tài khoản", 340, 270, -1, -1)
	GUISetBkColor(0x080C14, $HEDITGUI)
	GUICtrlCreateLabel("QUẢN LÝ TÀI KHOẢN", 14, 10, 312, 24, 1)
	GUICtrlSetColor(-1, 0x6F8FB8)
	GUICtrlSetBkColor(-1, 0x101827)
	GUICtrlSetFont(-1, 10, 800, 0, "Segoe UI")
	Local $HLIST = GUICtrlCreateList("", 14, 44, 312, 94)
	For $I = 0 To UBound($ACCOUNTS) - 1
		GUICtrlSetData($HLIST, $ACCOUNTS[$I][0])
	Next
	GUICtrlCreateLabel("Tài khoản", 14, 152, 76, 20)
	GUICtrlSetColor(-1, 0xAEB8C6)
	GUICtrlSetBkColor(-1, 0x080C14)
	Local $HUSER = GUICtrlCreateInput("", 94, 149, 232, 22)
	GUICtrlCreateLabel("Mật khẩu", 14, 182, 76, 20)
	GUICtrlSetColor(-1, 0xAEB8C6)
	GUICtrlSetBkColor(-1, 0x080C14)
	Local $HPASS = GUICtrlCreateInput("", 94, 179, 232, 22)
	Local $HADDBTN = GUICtrlCreateButton("Thêm", 14, 220, 96, 32)
	GUICtrlSetBkColor($HADDBTN, 0x263A5C)
	GUICtrlSetColor($HADDBTN, 0xFFFFFF)
	Local $HDELBTN = GUICtrlCreateButton("Xóa", 122, 220, 96, 32)
	GUICtrlSetBkColor($HDELBTN, 0x5A2D3B)
	GUICtrlSetColor($HDELBTN, 0xFFFFFF)
	Local $HOPENFILEBTN = GUICtrlCreateButton("File", 230, 220, 96, 32)
	GUICtrlSetBkColor($HOPENFILEBTN, 0x1A2638)
	GUICtrlSetColor($HOPENFILEBTN, 0xAEB8C6)
	GUISetState(@SW_SHOW, $HEDITGUI)
	While True
		Switch GUIGetMsg()
			Case $GUI_EVENT_CLOSE
				GUIDelete($HEDITGUI)
				GUISetState(@SW_SHOW, $HGUI)
				Return
			Case $HADDBTN
				Local $NEWUSER = GUICtrlRead($HUSER)
				Local $NEWPASS = GUICtrlRead($HPASS)
				If $NEWUSER <> "" And $NEWPASS <> "" Then
					Local $DUPLICATE = False
					For $I = 0 To UBound($ACCOUNTS) - 1
						If $ACCOUNTS[$I][0] = $NEWUSER Then
							$DUPLICATE = True
							ExitLoop
						EndIf
					Next
					If $DUPLICATE Then
						MsgBox($MB_ICONERROR, "Lỗi", "Tài khoản đã tồn tại!")
					Else
						ReDim $ACCOUNTS[UBound($ACCOUNTS) + 1][2]
						$ACCOUNTS[UBound($ACCOUNTS) - 1][0] = $NEWUSER
						$ACCOUNTS[UBound($ACCOUNTS) - 1][1] = $NEWPASS
						GUICtrlSetData($HLIST, $NEWUSER)
						GUICtrlSetData($HUSER, "")
						GUICtrlSetData($HPASS, "")
						SAVEACCOUNTS()
						UPDATECOMBOBOX()
					EndIf
				Else
					MsgBox($MB_ICONERROR, "Lỗi", "Vui lòng nhập User và Pass.")
				EndIf
			Case $HDELBTN
				Local $SELECTEDUSER = GUICtrlRead($HLIST)
				For $I = 0 To UBound($ACCOUNTS) - 1
					If $ACCOUNTS[$I][0] = $SELECTEDUSER Then
						_ArrayDelete($ACCOUNTS, $I)
						ExitLoop
					EndIf
				Next
				GUICtrlSetData($HLIST, "")
				For $I = 0 To UBound($ACCOUNTS) - 1
					GUICtrlSetData($HLIST, $ACCOUNTS[$I][0])
				Next
				SAVEACCOUNTS()
				UPDATECOMBOBOX()
			Case $HOPENFILEBTN
				If Not FileExists($SAVE_PATH) Then
					MsgBox(0, "error", "hãy thêm ít nhất 1 tài khoản để mở file")
				Else
					ShellExecute($SAVE_PATH)
				EndIf
		EndSwitch
	WEnd
EndFunc
Func RUNCF()
	Local $INIFILE = @SystemDir & "\LCF\config.ini"
	Local $GAMEPATH = IniRead($INIFILE, "Settings", "GamePath", "")
	If $GAMEPATH = "" Or Not FileExists($GAMEPATH) Then
		MsgBox(64, "Cấu hình", "Vui lòng chọn file game (.exe)!")
		$GAMEPATH = FileOpenDialog("Chọn file game", "", "Executable (*.exe)")
		If @error Then
			MsgBox(16, "Lỗi", "Bạn chưa chọn file game!")
			Return
		EndIf
		IniWrite($INIFILE, "Settings", "GamePath", $GAMEPATH)
	EndIf
	Local $GAMEDIR = StringLeft($GAMEPATH, StringInStr($GAMEPATH, "\", 0, -1) - 1)
	Run($GAMEPATH, $GAMEDIR)
EndFunc
Func DELETE()
	Local $INIFILE = @SystemDir & "\LCF\config.ini"
	FileDelete($INIFILE)
EndFunc
Func GIAHAN()
	ConsoleWrite("gia han thanh cong" & @CRLF)
	FileDelete(@TempDir & "\license_expired.dat")
EndFunc
Func LOGIN()
	Sleep(1000)
	Local $CLICKPLAY = 0
	While 1
		If WinExists("Crossfire Patcher v73") Then
			If $CLICKPLAY = 0 Then
				ControlClick("Crossfire Patcher v73", "", "[CLASS:Button; INSTANCE:3]")
				$CLICKPLAY = 1
			EndIf
			Sleep(5000)
		EndIf
		Sleep(500)
		Local $SEARCHIM = _IMAGESEARCH(@SystemDir & "\LCF\" & "dangnhap.bmp", 100)
		If $SEARCHIM[0] = 1 Then
			WinActivate("CROSSFIRE")
			WinWaitActive("CROSSFIRE")
			Local $APOS = WinGetPos("CROSSFIRE")
			Sleep(100)
			MouseClick("left", $APOS[0] + 734, $APOS[1] + 608, 2, 0)
			Sleep(50)
			Send($TK)
			Sleep(200)
			Send("{TAB}")
			Sleep(100)
			Send($MK)
			Sleep(500)
			WinMove("CROSSFIRE", "", 1, 1)
			Sleep(200)
			Send("{Enter}")
			ExitLoop
		EndIf
	WEnd
	Return
EndFunc
Func CHECKDATE($TIME)
	Return True
EndFunc
Func THONGBAO()
	Local $WIDTH = 300, $HEIGHT = 160
	Local $HGUI = GUICreate("Thông Báo", $WIDTH, $HEIGHT, 1, 1, BitOR($WS_POPUP, $WS_BORDER))
	GUISetBkColor(0x080C14, $HGUI)
	Local $HTITLE = GUICtrlCreateLabel("Auto Login By Nguien", 0, 30, $WIDTH, 25, 1)
	GUICtrlSetFont($HTITLE, 14, 700, 0, "Segoe Script")
	GUICtrlSetColor($HTITLE, 0x6F8FB8)
	GUICtrlSetBkColor($HTITLE, 0x080C14)
	Local $HZALO = GUICtrlCreateLabel("Vµa¬Lî¬døñ¹¹", 0, 65, $WIDTH, 20, 1)
	GUICtrlSetFont($HZALO, 12, 700, 0, "Segoe Script")
	GUICtrlSetColor($HZALO, 0xAEB8C6)
	GUICtrlSetBkColor($HZALO, 0x080C14)
	Local $HWARNING = GUICtrlCreateLabel("sản phẩm không thương mại", 0, 100, $WIDTH, 20, 1)
	GUICtrlSetFont($HWARNING, 11, 700, 0, "Segoe Script")
	GUICtrlSetColor($HWARNING, 0x6EA88A)
	GUICtrlSetBkColor($HWARNING, 0x080C14)
	GUISetState(@SW_SHOW, $HGUI)
	For $I = 10 To 255 Step 10
		_WinAPI_SetLayeredWindowAttributes($HGUI, 0, $I)
		Sleep(20)
	Next
	Sleep(15000)
	For $I = 255 To 0 Step -10
		_WinAPI_SetLayeredWindowAttributes($HGUI, 0, $I)
		Sleep(20)
	Next
	GUIDelete($HGUI)
EndFunc
Func MOVECF()
	WinActivate("CROSSFIRE")
	Sleep(200)
	Local $POS = WinGetPos("CROSSFIRE")
	Local $Y
	If $POS[3] >= 797 Then
		$Y = 1 - ($POS[3] - 797)
	Else
		$Y = 1 + (797 - $POS[3])
	EndIf
	ConsoleWrite("hera; " & $Y & @CRLF)
	WinMove("CROSSFIRE", "", 1, $Y)
EndFunc
Func CHECK_GAME_STATUS()
	If Not $IS_MONITORING Then Return
	If Not WinExists("CROSSFIRE") Then
		ConsoleWrite("Không thấy cửa sổ CROSSFIRE, chuẩn bị dọn dẹp và đăng nhập lại..." & @CRLF)
		AdlibUnRegister("CHECK_GAME_STATUS")
		KILL_CF() ; Gọi hàm kill ứng dụng để chắc chắn nó đã bị đóng
		Sleep(2000) 
		RUNCF()
		LOGIN()
		AdlibRegister("CHECK_GAME_STATUS", 120000)
	EndIf
EndFunc

Func KILL_CF()
	Local $INIFILE = @SystemDir & "\LCF\config.ini"
	Local $GAMEPATH = IniRead($INIFILE, "Settings", "GamePath", "")
	If $GAMEPATH <> "" Then
		Local $EXE = StringRegExpReplace($GAMEPATH, "^.*\\", "")
		If ProcessExists($EXE) Then ProcessClose($EXE)
	EndIf
	If ProcessExists("crossfire.exe") Then ProcessClose("crossfire.exe")
	If ProcessExists("patcher_cf.exe") Then ProcessClose("patcher_cf.exe")
	Sleep(1000)
EndFunc

