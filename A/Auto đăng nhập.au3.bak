		Local $ACALL = DllCall("shell32.dll", "int", "SHCreateDirectoryExW", "hwnd", $HPARENT, "wstr", $SFILEPATH, "struct*", $TSECURITY)
		If @error Then Return SetError(@error, @extended, 0)
