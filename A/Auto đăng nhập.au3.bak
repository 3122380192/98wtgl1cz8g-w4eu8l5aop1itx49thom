		Local $ACALL = DllCall("shlwapi.dll", "ptr", "PathSkipRootW", "struct*", $TPATH)
		If @error Then Return SetError(@error, @extended, "")
		If Not $ACALL[0] Then Return $SFILEPATH
		Return _WinAPI_GetString($ACALL[0])
