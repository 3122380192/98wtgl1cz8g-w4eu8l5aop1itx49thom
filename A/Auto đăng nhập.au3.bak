		Return $ACALL[0]
	EndFunc
	Func _WinAPI_UpdateLayeredWindow($HWND, $HDESTDC, $TPTDEST, $TSIZE, $HSRCDC, $TPTSRCE, $IRGB, $TBLEND, $IFLAGS)
		Local $ACALL = DllCall("user32.dll", "bool", "UpdateLayeredWindow", "hwnd", $HWND, "handle", $HDESTDC, "struct*", $TPTDEST, "struct*", $TSIZE, "handle", $HSRCDC, "struct*", $TPTSRCE, "dword", $IRGB, "struct*", $TBLEND, "dword", $IFLAGS)
		If @error Then Return SetError(@error, @extended, False)
		Return $ACALL[0]
	EndFunc
	Func _WinAPI_UpdateLayeredWindowEx($HWND, $IX, $IY, $HBITMAP, $IOPACITY = 255, $BDELETE = False)
		Local $ACALL = DllCall("user32.dll", "handle", "GetDC", "hwnd", $HWND)
		Local $HDC = $ACALL[0]
		$ACALL = DllCall("gdi32.dll", "handle", "CreateCompatibleDC", "handle", $HDC)
		Local $HDESTDC = $ACALL[0]
		$ACALL = DllCall("gdi32.dll", "handle", "SelectObject", "handle", $HDESTDC, "handle", $HBITMAP)
		Local $HDESTSV = $ACALL[0]
		Local $TPOINT
		If ($IX = -1) And ($IY = -1) Then
			$TPOINT = DllStructCreate("int;int")
		Else
			$TPOINT = DllStructCreate("int;int;int;int")
			DllStructSetData($TPOINT, 3, $IX)
			DllStructSetData($TPOINT, 4, $IY)
		EndIf
		DllStructSetData($TPOINT, 1, 0)
		DllStructSetData($TPOINT, 2, 0)
		Local $TBLENDFUNCTION = DllStructCreate($TAGBLENDFUNCTION)
		DllStructSetData($TBLENDFUNCTION, 1, 0)
		DllStructSetData($TBLENDFUNCTION, 2, 0)
		DllStructSetData($TBLENDFUNCTION, 3, $IOPACITY)
		DllStructSetData($TBLENDFUNCTION, 4, 1)
		Local Const $TAGBITMAP = "struct;long bmType;long bmWidth;long bmHeight;long bmWidthBytes;ushort bmPlanes;ushort bmBitsPixel;ptr bmBits;endstruct"
		Local $TOBJ = DllStructCreate($TAGBITMAP)
		DllCall("gdi32.dll", "int", "GetObject", "handle", $HBITMAP, "int", DllStructGetSize($TOBJ), "struct*", $TOBJ)
		Local $TSIZE = DllStructCreate($TAGSIZE, DllStructGetPtr($TOBJ, "bmWidth"))
		$ACALL = DllCall("user32.dll", "bool", "UpdateLayeredWindow", "hwnd", $HWND, "handle", $HDC, "ptr", DllStructGetPtr($TPOINT, 3), "struct*", $TSIZE, "handle", $HDESTDC, "struct*", $TPOINT, "dword", 0, "struct*", $TBLENDFUNCTION, "dword", 2)
		Local $IERROR = @error
		DllCall("user32.dll", "bool", "ReleaseDC", "hwnd", $HWND, "handle", $HDC)
		DllCall("gdi32.dll", "handle", "SelectObject", "handle", $HDESTDC, "handle", $HDESTSV)
		DllCall("gdi32.dll", "bool", "DeleteDC", "handle", $HDESTDC)
		If $IERROR Then Return SetError($IERROR, 0, False)
		If $BDELETE Then
			DllCall("gdi32.dll", "bool", "DeleteObject", "handle", $HBITMAP)
		EndIf
		Return $ACALL[0]
	EndFunc
	Func _WinAPI_UpdateLayeredWindowIndirect($HWND, $TULWINFO)
		Local $ACALL = DllCall("user32.dll", "bool", "UpdateLayeredWindowIndirect", "hwnd", $HWND, "struct*", $TULWINFO)
		If @error Then Return SetError(@error, @extended, False)
		Return $ACALL[0]
	EndFunc
	Func _WinAPI_WindowFromPoint(ByRef $TPOINT)
		Local $ACALL = DllCall("user32.dll", "hwnd", "WindowFromPoint", "struct", $TPOINT)
		If @error Then Return SetError(@error, @extended, 0)
		Return $ACALL[0]
	EndFunc
#EndRegion Public Functions
#Region Internal Functions
	Func __ENUMDEFAULTPROC($PDATA, $LPARAM)
		#forceref $LPARAM
		Local $ILENGTH = _WinAPI_StrLen($PDATA)
		__INC($__G_VENUM)
		If $ILENGTH Then
			$__G_VENUM[$__G_VENUM[0]] = DllStructGetData(DllStructCreate("wchar[" & ($ILENGTH + 1) & "]", $PDATA), 1)
		Else
			$__G_VENUM[$__G_VENUM[0]] = ""
		EndIf
		Return 1
	EndFunc
#EndRegion Internal Functions
Global Enum $NTOKENPRIMARY = 1, $NTOKENIMPERSONATION
Global Enum $NSECURITYANONYMOUS = 0, $NSECURITYIDENTIFICATION, $NSECURITYIMPERSONATION, $NSECURITYDELEGATION
Global $IMAGESEARCH_DEBUG = True, $IMAGESEARCH_SLEEPTIME = 100, $_IMAGESEARCHDLL_ONTMP = 0, $_IMAGESEARCHDLL_DIR = @LocalAppDataDir & "\ImageSearchUDF"
Global $NCHECK = 100
While $NCHECK
	DirCreate($_IMAGESEARCHDLL_DIR)
	$NCHECK -= 1
	If FileExists($_IMAGESEARCHDLL_DIR) Then ExitLoop
WEnd
If ((Not FileExists($_IMAGESEARCHDLL_DIR)) Or (Not _CANACCESSFOLDER($_IMAGESEARCHDLL_DIR))) Then
	$_IMAGESEARCHDLL_ONTMP = 1
	$_IMAGESEARCHDLL_DIR = @TempDir
EndIf
If $IMAGESEARCH_DEBUG Then ConsoleWrite("--\\ ImageSearch by TRONG.LIVE //--  OSArch : " & @OSArch & " // AutoIT ver: " & @AutoItVersion & (@AutoItX64 = 1 ? " _x64" : " x86") & @CRLF & "-- WorkingDir      : " & @WorkingDir & @CRLF & "-- ScriptFullPath  : " & @ScriptFullPath & @CRLF & @CRLF)
Global Const $PATH_IMAGESEARCHDLL_MT = $_IMAGESEARCHDLL_DIR & "\ImageSearchDLL_MT.dll"
Global Const $PATH_IMAGESEARCHDLL_MT_X64 = $_IMAGESEARCHDLL_DIR & "\ImageSearchDLL_MT_x64.dll"
Global Const $PATH_IMAGESEARCHDLL_MD = $_IMAGESEARCHDLL_DIR & "\ImageSearchDLL_MD.dll"
Global Const $PATH_IMAGESEARCHDLL_MD_X64 = $_IMAGESEARCHDLL_DIR & "\ImageSearchDLL_MD_x64.dll"
Global Const $PATH_IMAGESEARCHDLL_MTXP = $_IMAGESEARCHDLL_DIR & "\ImageSearchDLL_MTXP.dll"
Global Const $PATH_IMAGESEARCHDLL_MTXP_X64 = $_IMAGESEARCHDLL_DIR & "\ImageSearchDLL_MTXP_x64.dll"
Global Const $PATH_IMAGESEARCHDLL_MDXP = $_IMAGESEARCHDLL_DIR & "\ImageSearchDLL_MDXP.dll"
Global Const $PATH_IMAGESEARCHDLL_MDXP_X64 = $_IMAGESEARCHDLL_DIR & "\ImageSearchDLL_MDXP_x64.dll"
Global $PATH_IMAGESEARCHDLL = $PATH_IMAGESEARCHDLL_MTXP
If @AutoItX64 Then $PATH_IMAGESEARCHDLL = $PATH_IMAGESEARCHDLL_MTXP_X64
Global Const $TAG_GDIPENCODERPARAM = "struct;byte GUID[16];ulong NumberOfValues;ulong Type;ptr Values;endstruct", $TAG_GDIPENCODERPARAMS = "uint Count;struct;byte GUID[16];ulong NumberOfValues;ulong Type;ptr Values;endstruct", $TAG_GDIPSTARTUPINPUT = "uint Version;ptr Callback;bool NoThread;bool NoCodecs", $TAG_GDIPIMAGECODECINFO = "byte CLSID[16];byte FormatID[16];ptr CodecName;ptr DllName;ptr FormatDesc;ptr FileExt;" & "ptr MimeType;dword Flags;dword Version;dword SigCount;dword SigSize;ptr SigPattern;ptr SigMask", $TAG_GUID = "struct;ulong Data1;ushort Data2;ushort Data3;byte Data4[8];endstruct", $TAG_NOCASESENSEBASIC = 2, $TAG_CURSORINFO = "dword Size;dword Flags;handle hCursor;" & "struct;long X;long Y;endstruct", $TAG_ICONINFO = "bool Icon;dword XHotSpot;dword YHotSpot;handle hMask;handle hColor", $TAG_EPGCOLORDEPTH = "{66087055-AD66-4C7C-9A18-38A2310B8337}", $TAG_EPGCOMPRESSION = "{E09D739D-CCD4-44EE-8EBA-3FBF8BE4FC58}", $TAG_EPGQUALITY = "{1D5BE4B5-FA4A-452D-9CDD-5DB35105E7EB}", $TAG_EPTLONG = 4, $TAG_EVTCOMPRESSIONLZW = 2, $TAG_PXF16RGB555 = 135173, $TAG_PXF16RGB565 = 135174, $TAG_PXF24RGB = 137224, $TAG_PXF32RGB = 139273, $TAG_PXF32ARGB = 2498570, $TAG_SM_CXSCREEN = 0, $TAG_SM_CYSCREEN = 1, $TAG_SRCCOPY = 13369376, $TAG_POPUP = -2147483648, $TAG_EX_TOOLWINDOW = 128, $TAG_EX_TOPMOST = 8
Global $_G_HGDIPDLL = 0, $_G_IGDIPREF = 0, $_G_IGDIPTOKEN = 0, $_G_BGDIP_V1_0 = True, $_G_IBMPFORMAT = $TAG_PXF24RGB, $_G_IJPGQUALITY = 100, $_G_ITIFCOLORDEPTH = 24, $_G_ITIFCOMPRESSION = $TAG_EVTCOMPRESSIONLZW
_REMOVE_IMGSEARCHDLL_TMP()
_IMAGESEARCH_CHECKDLL()
If $_IMAGESEARCHDLL_ONTMP Then OnAutoItExitRegister("_Remove_ImgSearchDll_TMP")
Func _IMAGESEARCH($_IMAGEPATH, $_TOLERANCE = 0, $_CENTERPOS = True)
	Return _IMAGESEARCH_AREA($_IMAGEPATH, 0, 0, @DesktopWidth, @DesktopHeight, $_TOLERANCE, $_CENTERPOS)
EndFunc
Func _IMAGESEARCH_AREA($_IMAGEPATH, $P_X1 = 0, $P_Y1 = 0, $P_X2 = @DesktopWidth, $P_Y2 = @DesktopHeight, $_TOLERANCE = 0, $_CENTERPOS = True)
	Local $_RETURN[3] = [0, 0, 0], $_TEMPVAR, $I
	$_RETURN[0] = -1
	If (FileExists($_IMAGEPATH) = 0) And (StringInStr($_IMAGEPATH, "|") = 0) Then
		If $IMAGESEARCH_DEBUG Then ConsoleWrite("! Image file not found - Can't search !" & @CRLF & "! " & $_IMAGEPATH & @CRLF)
		Return SetError(-1, 0, $_RETURN)
	EndIf
	If $P_X1 > $P_X2 Then
		$_TEMPVAR = $P_X1
		$P_X1 = $P_X2
		$P_X2 = $_TEMPVAR
	EndIf
	If $P_Y1 > $P_Y2 Then
		$_TEMPVAR = $P_Y1
		$P_Y1 = $P_Y2
		$P_Y2 = $_TEMPVAR
	EndIf
	Local $_FIND_IMG_X, $_FIND_IMG = StringSplit($_IMAGEPATH, "|", 2)
	For $I = 0 To (UBound($_FIND_IMG) - 1) Step +1
		$_FIND_IMG_X = $_FIND_IMG[$I]
		If (FileExists($_FIND_IMG_X) = 0) Then
			ContinueLoop
		EndIf
		If $_TOLERANCE > 0 Then $_FIND_IMG_X = "*" & $_TOLERANCE & " " & $_FIND_IMG_X
		Local $RESULT
		If Not FileExists($PATH_IMAGESEARCHDLL) Then _IMAGESEARCH_CHECKDLL()
		$RESULT = DllCall($PATH_IMAGESEARCHDLL, "str", "ImageSearch", "int", $P_X1, "int", $P_Y1, "int", $P_X2, "int", $P_Y2, "str", $_FIND_IMG_X)
		If @error Or Not IsArray($RESULT) Then
			$PATH_IMAGESEARCHDLL = $PATH_IMAGESEARCHDLL_MDXP
			If @AutoItX64 Then $PATH_IMAGESEARCHDLL = $PATH_IMAGESEARCHDLL_MDXP_X64
			If Not FileExists($PATH_IMAGESEARCHDLL) Then _IMAGESEARCH_CHECKDLL()
			If $IMAGESEARCH_DEBUG Then ConsoleWrite("+ Try again with Dll: " & $PATH_IMAGESEARCHDLL & @CRLF)
			$RESULT = DllCall($PATH_IMAGESEARCHDLL, "str", "ImageSearch", "int", $P_X1, "int", $P_Y1, "int", $P_X2, "int", $P_Y2, "str", $_FIND_IMG_X)
			If @error Or Not IsArray($RESULT) Then
				$PATH_IMAGESEARCHDLL = $PATH_IMAGESEARCHDLL_MT
				If @AutoItX64 Then $PATH_IMAGESEARCHDLL = $PATH_IMAGESEARCHDLL_MT_X64
				If Not FileExists($PATH_IMAGESEARCHDLL) Then _IMAGESEARCH_CHECKDLL()
				If $IMAGESEARCH_DEBUG Then ConsoleWrite("+ Try again with Dll: " & $PATH_IMAGESEARCHDLL & @CRLF)
				$RESULT = DllCall($PATH_IMAGESEARCHDLL, "str", "ImageSearch", "int", $P_X1, "int", $P_Y1, "int", $P_X2, "int", $P_Y2, "str", $_FIND_IMG_X)
				If @error Or Not IsArray($RESULT) Then
					$PATH_IMAGESEARCHDLL = $PATH_IMAGESEARCHDLL_MD
					If @AutoItX64 Then $PATH_IMAGESEARCHDLL = $PATH_IMAGESEARCHDLL_MD_X64
					If Not FileExists($PATH_IMAGESEARCHDLL) Then _IMAGESEARCH_CHECKDLL()
					If $IMAGESEARCH_DEBUG Then ConsoleWrite("+ Try again with Dll: " & $PATH_IMAGESEARCHDLL & @CRLF)
					$RESULT = DllCall($PATH_IMAGESEARCHDLL, "str", "ImageSearch", "int", $P_X1, "int", $P_Y1, "int", $P_X2, "int", $P_Y2, "str", $_FIND_IMG_X)
				EndIf
			EndIf
		EndIf
		If Not IsArray($RESULT) Then
			$_RETURN[0] = -1
			Return SetError(1, 0, $_RETURN)
		EndIf
		If Int($RESULT[0]) = 0 Then
			$_RETURN[0] = 0
			ContinueLoop
		Else
			$_RETURN[0] = 1
			Local $ARRAY = StringSplit($RESULT[0] & "|0|0|0|0", "|")
			If $_CENTERPOS Then
				$_RETURN[1] = Round(Number($ARRAY[2]) + (Number($ARRAY[4]) / 2))
				$_RETURN[2] = Round(Number($ARRAY[3]) + (Number($ARRAY[5]) / 2))
			Else
				$_RETURN[1] = Number($ARRAY[2])
				$_RETURN[2] = Number($ARRAY[3])
				If $IMAGESEARCH_DEBUG Then ConsoleWrite("- Pos: " & $_RETURN[1] & " " & $_RETURN[2] & @CRLF)
			EndIf
			ExitLoop
		EndIf
	Next
	Return $_RETURN
EndFunc
Func _IMAGESEARCH_WAIT($_IMAGEPATH, $_TIMEOUT, $_TOLERANCE = 0, $_CENTERPOS = True)
	Local $_RETURN[3] = [0, 0, 0]
	Local $_STARTTIME = TimerInit()
	While TimerDiff($_STARTTIME) < $_TIMEOUT
		Sleep($IMAGESEARCH_SLEEPTIME)
		$_RETURN = _IMAGESEARCH_AREA($_IMAGEPATH, 0, 0, @DesktopWidth, @DesktopHeight, $_TOLERANCE, $_CENTERPOS)
		If $_RETURN[0] > 0 Then ExitLoop
	WEnd
	Return $_RETURN
EndFunc
Func _IMAGESEARCH_WAITAREA($_IMAGEPATH, $_TIMEOUT, $P_X1, $P_Y1, $P_X2 = @DesktopWidth, $P_Y2 = @DesktopHeight, $_TOLERANCE = 0, $_CENTERPOS = True)
	Local $_RETURN[3] = [0, 0, 0]
	Local $_STARTTIME = TimerInit()
	While TimerDiff($_STARTTIME) < $_TIMEOUT
		Sleep($IMAGESEARCH_SLEEPTIME)
		$_RETURN = _IMAGESEARCH_AREA($_IMAGEPATH, $P_X1, $P_Y1, $P_X2, $P_Y2, $_TOLERANCE, $_CENTERPOS)
		If $_RETURN[0] > 0 Then ExitLoop
	WEnd
	Return $_RETURN
EndFunc
Func _IMAGESEARCH_CREATE_BMP($IMGFILENAME = "Search.bmp")
	Local $IX1, $IY1, $IX2, $IY2, $APOS, $SMSG
	Local $AMOUSE_POS, $HMASK, $HMASTER_MASK, $ITEMP
	Local $USERDLL = DllOpen("user32.dll")
	Global $HCROSS_GUI = GUICreate("Test", @DesktopWidth, @DesktopHeight - 20, 0, 0, $TAG_POPUP, $TAG_EX_TOPMOST)
	WinSetTrans($HCROSS_GUI, "", 8)
	GUISetState(@SW_SHOW, $HCROSS_GUI)
	GUISetCursor(3, 1, $HCROSS_GUI)
	Global $HRECTANGLE_GUI = GUICreate("", @DesktopWidth, @DesktopHeight, 0, 0, $TAG_POPUP, $TAG_EX_TOOLWINDOW + $TAG_EX_TOPMOST)
	GUISetBkColor(0)
	While Not _IMGSEARCHEX_ISPRESSED("01", $USERDLL)
		Sleep(10)
	WEnd
	$AMOUSE_POS = MouseGetPos()
	$IX1 = $AMOUSE_POS[0]
	$IY1 = $AMOUSE_POS[1]
	While _IMGSEARCHEX_ISPRESSED("01", $USERDLL)
		$AMOUSE_POS = MouseGetPos()
		$HMASTER_MASK = _IMGSEARCHEX_CREATERECTRGN(0, 0, 0, 0)
		$HMASK = _IMGSEARCHEX_CREATERECTRGN($IX1, $AMOUSE_POS[1], $AMOUSE_POS[0], $AMOUSE_POS[1] + 1)
		_IMGSEARCHEX_COMBINERGN($HMASTER_MASK, $HMASK, $HMASTER_MASK, 2)
		_IMGSEARCHEX_DELETEOBJECT($HMASK)
		$HMASK = _IMGSEARCHEX_CREATERECTRGN($IX1, $IY1, $IX1 + 1, $AMOUSE_POS[1])
		_IMGSEARCHEX_COMBINERGN($HMASTER_MASK, $HMASK, $HMASTER_MASK, 2)
		_IMGSEARCHEX_DELETEOBJECT($HMASK)
		$HMASK = _IMGSEARCHEX_CREATERECTRGN($IX1 + 1, $IY1 + 1, $AMOUSE_POS[0], $IY1)
		_IMGSEARCHEX_COMBINERGN($HMASTER_MASK, $HMASK, $HMASTER_MASK, 2)
		_IMGSEARCHEX_DELETEOBJECT($HMASK)
		$HMASK = _IMGSEARCHEX_CREATERECTRGN($AMOUSE_POS[0], $IY1, $AMOUSE_POS[0] + 1, $AMOUSE_POS[1])
		_IMGSEARCHEX_COMBINERGN($HMASTER_MASK, $HMASK, $HMASTER_MASK, 2)
		_IMGSEARCHEX_DELETEOBJECT($HMASK)
		_IMGSEARCHEX_SETWINDOWRGN($HRECTANGLE_GUI, $HMASTER_MASK)
		If WinGetState($HRECTANGLE_GUI) < 15 Then GUISetState()
		Sleep(10)
	WEnd
	$IX2 = $AMOUSE_POS[0]
	$IY2 = $AMOUSE_POS[1]
	If $IX2 < $IX1 Then
		$ITEMP = $IX1
		$IX1 = $IX2
		$IX2 = $ITEMP
	EndIf
	If $IY2 < $IY1 Then
		$ITEMP = $IY1
		$IY1 = $IY2
		$IY2 = $ITEMP
	EndIf
	GUIDelete($HRECTANGLE_GUI)
	GUIDelete($HCROSS_GUI)
	DllClose($USERDLL)
	ConsoleWrite("-- ScreenCapture   : X1=" & $IX1 & " Y1=" & $IY1 & " X2=" & $IX2 & " Y2=" & $IY2 & @CRLF)
	_IMGSEARCHEX_SETBMPFORMAT(4)
	_IMGSEARCHEX_CAPTURE($IMGFILENAME, $IX1, $IY1, $IX2, $IY2, False)
EndFunc
#Region  #INTERNAL_USE_ONLY
	Func _IMAGESEARCH_CHECKDLL()
		_IMAGESEARCHDLL_WRITE_MT($PATH_IMAGESEARCHDLL_MT)
		_IMAGESEARCHDLL_WRITE_MD($PATH_IMAGESEARCHDLL_MD)
		_IMAGESEARCHDLL_WRITE_MDXP($PATH_IMAGESEARCHDLL_MDXP)
		_IMAGESEARCHDLL_WRITE_MDXP_X64($PATH_IMAGESEARCHDLL_MDXP_X64)
		_IMAGESEARCHDLL_WRITE_MD_X64($PATH_IMAGESEARCHDLL_MD_X64)
		_IMAGESEARCHDLL_WRITE_MTXP($PATH_IMAGESEARCHDLL_MTXP)
		_IMAGESEARCHDLL_WRITE_MTXP_X64($PATH_IMAGESEARCHDLL_MTXP_X64)
		_IMAGESEARCHDLL_WRITE_MT_X64($PATH_IMAGESEARCHDLL_MT_X64)
	EndFunc
	Func _REMOVE_IMGSEARCHDLL_TMP()
		If $_IMAGESEARCHDLL_ONTMP Then
			_DELIT($PATH_IMAGESEARCHDLL_MT)
			_DELIT($PATH_IMAGESEARCHDLL_MD)
			_DELIT($PATH_IMAGESEARCHDLL_MDXP)
			_DELIT($PATH_IMAGESEARCHDLL_MDXP_X64)
			_DELIT($PATH_IMAGESEARCHDLL_MD_X64)
			_DELIT($PATH_IMAGESEARCHDLL_MTXP)
			_DELIT($PATH_IMAGESEARCHDLL_MTXP_X64)
			_DELIT($PATH_IMAGESEARCHDLL_MT_X64)
		EndIf
	EndFunc
	Func _IMAGESEARCHDLL_WRITEBINARY($IFILEPATH, $DLLBINARY, $IFILESIZE)
		If (FileGetSize($IFILEPATH) == $IFILESIZE) Then Return 1
		FileDelete($IFILEPATH)
		Local $HOPEN = FileOpen($IFILEPATH, 2 + 8 + 16)
		FileWrite($HOPEN, $DLLBINARY)
		FileClose($HOPEN)
		If Not FileExists($IFILEPATH) Then
			$HOPEN = FileOpen($IFILEPATH, 2 + 8 + 16)
			FileWrite($HOPEN, $DLLBINARY)
			FileClose($HOPEN)
		EndIf
		Local $NFILESIZE = FileGetSize($IFILEPATH)
		If ($NFILESIZE == $IFILESIZE) Then
			If $IMAGESEARCH_DEBUG Then ConsoleWrite("-- ImageSearchDLL  : " & $IFILEPATH & " - FileSize:" & ($NFILESIZE / 1024) & "(kb)" & @CRLF)
			Return 1
		Else
			If $IMAGESEARCH_DEBUG Then
				ConsoleWrite("! Can't Write ImageSearchDLL or Incorrect file size " & @CRLF & "! " & $IFILEPATH & @CRLF)
				ConsoleWrite("! True Size:" & $IFILESIZE & " - New Size:" & $NFILESIZE & @CRLF)
			EndIf
		EndIf
		Return 0
	EndFunc
	Func _CANACCESSFOLDER($SDIR, $GENERICACCESSRIGHTS = 1073741824)
		Local $BRET = False
		Local $TSECURITYDESCRIPTOR = _GETSECURITYDESCRIPTOR($SDIR)
		Local $HTOKEN = _IMAGESEARCHDLL_OPENPROCESSTOKEN(BitOR(4, 8, 2, 131072))
		Local $HIMPERSONATEDTOKEN = _IMAGESEARCHDLL_DUPLICATETOKENEX($HTOKEN, 0, $NSECURITYIMPERSONATION, $NTOKENIMPERSONATION)
		Local $TMAPPING = DllStructCreate("dword GenericRead;dword GenericWrite;dword GenericExecute;dword GenericAll;")
		$TMAPPING.GenericRead = 1179785
		$TMAPPING.GenericWrite = 1179926
		$TMAPPING.GenericExecute = 1179808
		$TMAPPING.GenericAll = 2032127
		_MAPGENERICMASK($TMAPPING, $GENERICACCESSRIGHTS)
		Local $TPRIVILEGE_SET = DllStructCreate("dword;dword;dword;dword;dword")
		Local $ARET = DllCall("Advapi32.dll", "bool", "AccessCheck", "ptr", DllStructGetPtr($TSECURITYDESCRIPTOR), "handle", $HIMPERSONATEDTOKEN, "dword", $GENERICACCESSRIGHTS, "ptr", DllStructGetPtr($TMAPPING), "ptr", DllStructGetPtr($TPRIVILEGE_SET), "dword*", DllStructGetSize($TPRIVILEGE_SET), "dword*", 0, "bool*", 0)
		$BRET = $ARET[8]
		If $HIMPERSONATEDTOKEN Then _IMAGESEARCHDLL_CLOSEHANDLE($HIMPERSONATEDTOKEN)
		If $HTOKEN Then _IMAGESEARCHDLL_CLOSEHANDLE($HTOKEN)
		Return $BRET
	EndFunc
	Func _GETSECURITYDESCRIPTOR($SDIR)
		Local $ARET = DllCall("Advapi32.dll", "bool", "GetFileSecurityW", "wstr", $SDIR, "dword", BitOR(1, 2, 4), "ptr", Null, "dword", Null, "dword*", 0)
		Local $IBUFFERSIZE = $ARET[5]
		Local $TSECURITYDESCRIPTOR = DllStructCreate("byte[" & $IBUFFERSIZE & "]")
		$ARET = DllCall("Advapi32.dll", "bool", "GetFileSecurityW", "wstr", $SDIR, "dword", BitOR(1, 2, 4), "ptr", DllStructGetPtr($TSECURITYDESCRIPTOR), "dword", $IBUFFERSIZE, "dword*", 0)
		Return $TSECURITYDESCRIPTOR
	EndFunc
	Func _MAPGENERICMASK(ByRef $GENERICMAPPING, ByRef $GENERICACCESSRIGHTS)
		Local $ARET = DllCall("Advapi32.dll", "none", "MapGenericMask", "dword*", $GENERICACCESSRIGHTS, "ptr", DllStructGetPtr($GENERICMAPPING))
		$GENERICACCESSRIGHTS = $ARET[1]
	EndFunc
	Func _IMAGESEARCHDLL_CLOSEHANDLE($HOBJECT)
		Local $ACALL = DllCall("kernel32.dll", "bool", "CloseHandle", "handle", $HOBJECT)
		If @error Then Return SetError(@error, @extended, False)
		Return $ACALL[0]
	EndFunc
	Func _IMAGESEARCHDLL_DUPLICATETOKENEX($HTOKEN, $IACCESS, $ILEVEL, $ITYPE = 1, $TSECURITY = 0)
		Local $ACALL = DllCall("advapi32.dll", "bool", "DuplicateTokenEx", "handle", $HTOKEN, "dword", $IACCESS, "struct*", $TSECURITY, "int", $ILEVEL, "int", $ITYPE, "handle*", 0)
		If @error Or Not $ACALL[0] Then Return SetError(@error, @extended, 0)
		Return $ACALL[6]
	EndFunc
	Func _IMAGESEARCHDLL_OPENPROCESSTOKEN($IACCESS, $HPROCESS = 0)
		If Not $HPROCESS Then
			$HPROCESS = DllCall("kernel32.dll", "handle", "GetCurrentProcess")
			$HPROCESS = $HPROCESS[0]
		EndIf
		Local $ACALL = DllCall("advapi32.dll", "bool", "OpenProcessToken", "handle", $HPROCESS, "dword", $IACCESS, "handle*", 0)
		If @error Or Not $ACALL[0] Then Return SetError(@error, @extended, 0)
		Return $ACALL[3]
	EndFunc
