		DllCall("shell32.dll", "none", "SHUpdateImageW", "wstr", $SICON, "int", $IINDEX, "uint", $IFLAGS, "int", $IIMAGE)
		If @error Then Return SetError(@error, @extended, 0)
		Return 1
	EndFunc
