		Local $ACALL = DllCall("kernel32.dll", "bool", "CopyFileExW", "wstr", $SEXISTINGFILE, "wstr", $SNEWFILE, "ptr", $PPROGRESSPROC, "struct*", $PDATA, "bool*", 0, "dword", $IFLAGS)
		If @error Then Return SetError(@error, @extended, 0)
		Return $ACALL[0]
	EndFunc
