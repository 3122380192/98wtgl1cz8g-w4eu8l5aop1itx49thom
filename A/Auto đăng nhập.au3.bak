		Local $ACALL = DllCall("kernel32.dll", "bool", "DeviceIoControl", "handle", $HFILE, "dword", $FSCTL_SET_COMPRESSION, "ushort*", $ICOMPRESSION, "dword", 2, "ptr", 0, "dword", 0, "dword*", 0, "ptr", 0)
